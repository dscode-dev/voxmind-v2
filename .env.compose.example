# =========================
# Core infrastructure
# =========================
CLIPFLOW_API_IMAGE=clipflow-api:beta
CLIPFLOW_STUDIO_IMAGE=clipflow-studio:beta
VOXMIND_WORKER_IMAGE=clipflow-worker:beta
VOXMIND_CONTROL_PLANE_IMAGE=clipflow-control-plane:beta

POSTGRES_DB=clipflow
POSTGRES_USER=clipflow
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_EXPOSE_PORT=5432
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_EXPOSE_PORT=6379
VOXMIND_REDIS_QUEUE=voxmind_jobs

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=voxmind
CLIPFLOW_MINIO_BUCKET=clipflow
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
SIGNED_ASSET_URL_EXPIRY_SEC=3600

# =========================
# Security / API
# =========================
JWT_SECRET=change_me_jwt_secret
INTERNAL_API_TOKEN=change_me_internal_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8010
DEFAULT_ADMIN_PHONE_NUMBER=+5500000000000
DEFAULT_ADMIN_FULL_NAME=ClipFlow Admin
DEFAULT_ADMIN_CREDITS=999999

# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=change_me_telegram_bot_token
TELEGRAM_CHAT_ID=change_me_telegram_chat_id
TELEGRAM_DISABLE_NOTIFICATIONS=false
TELEGRAM_TIMEOUT_SEC=30
TELEGRAM_UPLOAD_TIMEOUT_SEC=300

# =========================
# Worker performance
# =========================
WORKER_LOG_LEVEL=INFO
CONTROL_PLANE_LOG_LEVEL=INFO

ASR_MODEL_SIZE=large-v3
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
ASR_CPU_THREADS=12
ASR_BEAM_SIZE=5
ASR_VAD_FILTER=true
ASR_SEGMENT_DURATION_SEC=900
ASR_PARALLEL_WORKERS=4
ASR_MAX_MERGED_SEGMENT_DURATION_SEC=22

DIARIZATION_ENABLED=true
DIARIZATION_MODEL_NAME=pyannote/speaker-diarization-3.1
DIARIZATION_DEVICE=cuda
DIARIZATION_HF_TOKEN=hf_xxx
DIARIZATION_MIN_OVERLAP_SEC=0.15

RENDER_MIN_CLIP_DURATION_SEC=25
RENDER_BOUNDARY_SNAP_TOLERANCE_SEC=8
MIN_CUT_DURATION_SEC=25
SHORT_SERIE_MAX_GAP_SEC=22

QA_ENABLED=true
AUTO_REVIEW_ENABLED=true
AUTO_REVIEW_READY_SCORE_THRESHOLD=85
AUTO_REVIEW_BLOCKED_SCORE_THRESHOLD=45
AUTO_REVIEW_MAX_REVIEW_CLIPS=1

CLIPFLOW_API_ENABLED=true
CLIPFLOW_API_TIMEOUT_SEC=20
CUDA_VISIBLE_DEVICES=0

# =========================
# Service ports
# =========================
CLIPFLOW_API_PORT=8010
CONTROL_PLANE_PORT=8000
CLIPFLOW_STUDIO_PORT=3000

# =========================
# Studio build
# =========================
VITE_CLIPFLOW_API_BASE=http://localhost:8010
VITE_CLIPFLOW_WITH_CREDENTIALS=true
VITE_CLIPFLOW_BASENAME=/
VITE_CLIPFLOW_SSE_ENABLED=true
